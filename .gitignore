# Python
.venv/
__pycache__/
*.pyc
*.pyo

# Project data — never commit
output/
.checkpoints/

# Secrets — NEVER commit
.env

# Local databases
team_actions.db
*.db
*.duckdb
*.sqlite

# OS / IDE
Thumbs.db
.DS_Store
.vscode/
.idea/

# Logs
*.log

# Streamlit disk-persisted cache (rebuilds itself; never useful in git)
.streamlit/cache/

# Render-specific local artifacts
.render/

# Local backup archives — never commit (use Drive / S3 / B2 instead)
*.zip
*.tar
*.tar.gz
*.tgz
